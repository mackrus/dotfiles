"$schema" = "https://raw.githubusercontent.com/JanDeDobbeleer/oh-my-posh/main/themes/schema.json"
version = 2

[palette]
background = "#282c34"
text = "#abb2bf"
blue = "#61afef"
green = "#98c379"
red = "#e06c75"
yellow = "#e5c07b"
purple = "#c678dd"
cyan = "#56b6c2"
gray = "#4b5263"

[[blocks]]
alignment = "left"
type = "prompt"

[[blocks.segments]]
type = "path"
style = "powerline"
powerline_symbol = "\uE0B0"
foreground = "p:text"
background = "p:blue"
properties = { style = "folder", template = "\uF07B {{ .Path }}" }

[[blocks.segments]]
type = "git"
style = "powerline"
powerline_symbol = "\uE0B0"
foreground = "p:text"
background = "p:green"
background_templates = ["{{ if or (.Working.Changed) (.Staging.Changed) }}p:red{{ end }}"]
properties = { fetch_status = true }

[[blocks.segments]]
type = "status"
style = "plain"
foreground = "p:green"
foreground_templates = ["{{ if .Error }}p:red{{ end }}"]
properties = { always_enabled = true, template = "{{ if .Error }}\u2717{{ else }}\u2713{{ end }} " }

[[blocks.segments]]
type = "text"
style = "plain"
foreground = "p:text"
properties = { text = "\u276f" }

[[blocks]]
alignment = "right"
type = "rprompt"

[[blocks.segments]]
type = "time"
style = "powerline"
powerline_symbol = "\uE0B2"
invert_powerline = true
foreground = "p:text"
background = "p:gray"
properties = { time_format = "15:04:05", template = "\uF017 {{ .CurrentDate | date .Format }}" }
