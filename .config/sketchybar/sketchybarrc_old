# Center: Clock
sketchybar --add item clock center \
           --set clock update_freq=10 \
                       icon= \
                       script="sketchybar --set \$NAME label=\$(date '+%H:%M %b %d')"

# Right: System stats
sketchybar --add item battery right \
           --set battery update_freq=60 \
                        script="sketchybar --set \$NAME label=\$(pmset -g batt | grep -o '[0-9]\+%')" \
                        icon= \
sketchybar --add item cpu right \
           --set cpu icon= \
                     update_freq=5 \
                     icon.color=0xff88c0d0  # Teal accent
                     label.color=0xffd8dee9 \
                     icon.font="FiraCode Nerd Font:Regular:12.0" \
                     script="echo \$(top -l 1 | grep -E '^CPU usage' | awk '{print \$2}' | cut -d '%' -f1)% > /tmp/cpu_debug.txt; sketchybar --set \$NAME label=\$(cat /tmp/cpu_debug.txt)"

##### Force all scripts to run the first time (never do this in a script) #####
sketchybar --update

