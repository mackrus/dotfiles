vim.api.nvim_create_autocmd("User", {
	pattern = "VeryLazy",
	callback = function()
		local ok, Job = pcall(require, "plenary.job")
		if not ok then
			vim.notify("plenary.nvim not found", vim.log.levels.ERROR)
			return
		end

		local function run_file()
			local filetype = vim.bo.filetype
			local file = vim.fn.expand("%:p")
            vim.cmd("write")
			vim.notify("run_file: Filetype=" .. filetype .. ", File=" .. file, vim.log.levels.INFO)

			local cmd = nil
			if filetype == "rust" then
				cmd = "cargo run"
            elseif filetype == "tex" then
				cmd = "pdflatex -shell-escape ".. vim.fn.shellescape(file)
			elseif filetype == "python" then
				local uv_path = vim.fn.exepath("uv")
				if uv_path == "" then
					vim.notify("uv not found, using python3", vim.log.levels.WARN)
					cmd = "python3 " .. vim.fn.shellescape(file)
				else
					cmd = uv_path .. " run python " .. vim.fn.shellescape(file)
				end
			elseif filetype == "lua" then
				vim.api.nvim_exec2("source " .. file, {})
				vim.notify("Lua sourced: " .. file, vim.log.levels.INFO)
				return
			elseif filetype == "typst" then
				local tinymist_path = vim.fn.exepath("tinymist")
				if tinymist_path == "" then
					vim.notify("tinymist not found", vim.log.levels.ERROR)
					return
				end
				cmd = tinymist_path .. " compile " .. vim.fn.shellescape(file)
			else
				vim.notify("No run command for filetype: " .. filetype, vim.log.levels.WARN)
				return
			end

			if cmd then
				vim.notify("run_file: Running: tmux split-window -v -p 40 '" .. cmd .. "'", vim.log.levels.INFO)
				Job:new({
					command = vim.fn.exepath("tmux"),
					args = {
						"split-window",
						"-h",
						"bash",
						"-c",
						cmd .. "; echo ''; read -n 1 -s -r -p 'Press any key to close';",
					},
					on_exit = function(j, return_val)
						if return_val ~= 0 then
							vim.notify("Run failed: " .. table.concat(j:stderr_result(), "\n"), vim.log.levels.ERROR)
						else
							vim.notify("Run succeeded", vim.log.levels.INFO)
						end
					end,
			}):start()
			end
		end

		vim.keymap.set("n", "<leader>r", run_file, { desc = "Run file", noremap = true, silent = true })
	end,
})
