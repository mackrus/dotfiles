# new-window -d -n spf
# select-window -t 1
# send-keys -t mac:1.0 'cd ~/.config/ && spf' C-m
#
# # Window 2: neovim
# new-window -d -n nvim
# select-window -t 2
# send-keys -t mac:2.0 'n' C-m       


# Bind Ctrl+alt+0 to Ctrl+alt+4 to switch windows
bind -n M-1 select-window -t 0
bind -n M-2 select-window -t 1
bind -n M-3 select-window -t 2
bind -n M-4 select-window -t 3
bind -n M-5 select-window -t 4
bind -n M-6 select-window -t 5
bind -n M-7 select-window -t 6
bind -n M-8 select-window -t 7

bind-key -n M-j next-window
bind-key -n M-k previous-window

bind -n M-n new-window -c "#{pane_current_path}"
bind -n M-w kill-window
